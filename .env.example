# NASA API Key
NASA_API_KEY=

# N2YO API Key
N2YO_API_KEY=

# Telegram Bot Token
BOT_TOKEN=

# Default location (Kyiv, Ukraine - can be changed for user)
DEFAULT_LAT=
DEFAULT_LON=
DEFAULT_ALT=

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# Geoapify API Key (for maps)
GEOAPIFY_KEY=

# Feedback form (footer modal → POST /api/feedback → bot forwards to this
# Telegram chat). The recipient must have started the bot first. Reuses
# BOT_TOKEN; without it the endpoint returns 503 ("service unavailable").
FEEDBACK_CHAT_ID=372391903
